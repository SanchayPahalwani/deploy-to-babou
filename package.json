{
  "name": "deploy-to-babou",
  "version": "0.1.0",
  "description": "Every merge drafts a Babou launch campaign — agentically, through Babou's own MCP server. Export stays a human's call.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "context": "tsx scripts/build-context.ts",
    "demo": "tsx scripts/run-rest.ts",
    "agent": "tsx scripts/run-agent.ts",
    "assert": "tsx scripts/assert-draft.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "summary": "tsx scripts/summary.ts",
    "verify": "npm run typecheck && npm run test && npm run demo && npm run assert"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
